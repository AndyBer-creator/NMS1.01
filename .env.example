# Копируйте в .env и подставьте свои значения. Файл .env не коммитить!

# Локальное время (IANA): логи, формат дат в UI, Postgres session timezone в контейнере
# Примеры: Europe/Moscow, Asia/Yekaterinburg, UTC
TZ=Europe/Moscow

# PostgreSQL (контейнер postgres)
POSTGRES_DB=NMS
POSTGRES_USER=nms-user
POSTGRES_PASSWORD=your-postgres-password

# Строка подключения к БД для migration, trap-receiver и docker-compose.bridge.yml (сервисы в bridge-сети).
# Пароль должен совпадать с POSTGRES_PASSWORD.
# Основной docker-compose.yml: api и worker берут БД из compose (127.0.0.1 + POSTGRES_PASSWORD), не из этой строки.
DB_DSN=host=postgres port=5432 user=nms-user password=your-postgres-password dbname=NMS sslmode=disable
# Для основного docker-compose.yml (api/worker в host network):
# DB_SSLMODE управляет sslmode в DSN api/worker (default disable для локального single-host).
# Для production задайте минимум require (лучше verify-full при настроенных сертификатах).
# DB_SSLMODE=require
# Опционально: читать DSN из Docker secret-файла (приоритет выше DB_DSN)
# DB_DSN_FILE=/run/secrets/db_dsn
# Шифрование SNMP credential-полей в БД (community/auth_pass/priv_pass), рекомендуется для production.
# NMS_DB_ENCRYPTION_KEY=long-random-secret
# NMS_DB_ENCRYPTION_KEY_FILE=/run/secrets/nms_db_encryption_key
# Для ротации ключа (одноразово, во время процедуры re-encrypt):
# NMS_DB_ENCRYPTION_OLD_KEY=previous-long-random-secret
# NMS_DB_ENCRYPTION_OLD_KEY_FILE=/run/secrets/nms_db_encryption_old_key

# Telegram-бот для алертов (api, trap-receiver)
TELEGRAM_TOKEN=your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-chat-id
# TELEGRAM_TOKEN_FILE=/run/secrets/telegram_token
# TELEGRAM_CHAT_ID_FILE=/run/secrets/telegram_chat_id

# SMTP для email-алертов (Alertmanager -> API webhook -> SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=change-me
SMTP_FROM=alerts@example.com
# Legacy override (не рекомендуется): разрешить plaintext SMTP без STARTTLS.
# NMS_SMTP_ALLOW_PLAINTEXT=false
# SMTP_USER_FILE=/run/secrets/smtp_user
# SMTP_PASS_FILE=/run/secrets/smtp_pass
# SMTP_FROM_FILE=/run/secrets/smtp_from

# Каталог загрузки MIB через веб (опционально; иначе из config.yaml / по умолчанию mibs/uploads)
# MIB_UPLOAD_DIR=/app/mibs/uploads

# Grafana (опционально)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password

# Веб-вход NMS1: по умолчанию fail-closed (если пары логина/пароля не заданы, сервис вернет 503).
# Форма /login + cookie-сессия; при желании можно использовать HTTP Basic.
# NMS_SESSION_SECRET настоятельно рекомендуется для production.
# NMS_ADMIN_USER=admin
# NMS_ADMIN_PASS=change-me
# NMS_VIEWER_USER=viewer
# NMS_VIEWER_PASS=change-me-too
# NMS_SESSION_SECRET=long-random-string
# NMS_ALLOW_NO_AUTH=false
# NMS_ADMIN_USER_FILE=/run/secrets/nms_admin_user
# NMS_ADMIN_PASS_FILE=/run/secrets/nms_admin_pass
# NMS_VIEWER_USER_FILE=/run/secrets/nms_viewer_user
# NMS_VIEWER_PASS_FILE=/run/secrets/nms_viewer_pass
# NMS_SESSION_SECRET_FILE=/run/secrets/nms_session_secret

# Terminal WS security (admin page /devices/{id}/terminal):
# - по умолчанию strict Origin-check и строгая проверка SSH host key.
# - для SSH укажите known_hosts-файл; insecure режимы только временно/осознанно.
# NMS_TERMINAL_SSH_KNOWN_HOSTS=/app/secrets/known_hosts
# NMS_TERMINAL_ALLOW_INSECURE_HOSTKEY=false
# NMS_TERMINAL_ALLOW_INSECURE_ORIGIN=false

# HTTP server hardening (опционально):
# NMS_HTTP_READ_HEADER_TIMEOUT=5s
# NMS_HTTP_READ_TIMEOUT=15s
# NMS_HTTP_WRITE_TIMEOUT=30s
# NMS_HTTP_IDLE_TIMEOUT=60s
# NMS_HTTP_MAX_HEADER_BYTES=1048576
# NMS_WORKER_HTTP_READ_HEADER_TIMEOUT=5s
# NMS_WORKER_HTTP_READ_TIMEOUT=10s
# NMS_WORKER_HTTP_WRITE_TIMEOUT=20s
# NMS_WORKER_HTTP_IDLE_TIMEOUT=60s
# NMS_WORKER_HTTP_MAX_HEADER_BYTES=1048576
# Worker poll scaling (опционально):
# NMS_WORKER_POLL_CONCURRENCY=4
# NMS_WORKER_POLL_RATE_LIMIT_PER_SEC=0

# HTTPS-only policy (production): redirect plain HTTP to HTTPS (except /health and /metrics).
# NMS_ENFORCE_HTTPS=true

# Production guardrails:
# Если NMS_ENV=production, приложение требует:
# - NMS_SESSION_SECRET
# - NMS_DB_ENCRYPTION_KEY
# - NMS_TERMINAL_SSH_KNOWN_HOSTS
# - DB_DSN без sslmode=disable
# - NMS_ENFORCE_HTTPS=true
# И запрещает insecure-flags:
# - NMS_ALLOW_NO_AUTH
# - NMS_TERMINAL_ALLOW_INSECURE_ORIGIN
# - NMS_TERMINAL_ALLOW_INSECURE_HOSTKEY
