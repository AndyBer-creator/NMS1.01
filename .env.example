# Копируйте в .env и подставьте свои значения. Файл .env не коммитить!

# Локальное время (IANA): логи, формат дат в UI, Postgres session timezone в контейнере
# Примеры: Europe/Moscow, Asia/Yekaterinburg, UTC
TZ=Europe/Moscow

# PostgreSQL (контейнер postgres)
POSTGRES_DB=NMS
POSTGRES_USER=nms-user
POSTGRES_PASSWORD=your-postgres-password
# postgres-exporter в compose использует эти же значения
# (через DATA_SOURCE_NAME внутри docker-compose*.yml).

# Строка подключения к БД для migration, trap-receiver и deploy/compose/docker-compose.bridge.yml (сервисы в bridge-сети).
# Пароль должен совпадать с POSTGRES_PASSWORD.
# Основной deploy/compose/docker-compose.yml: api и worker берут БД из compose (127.0.0.1 + POSTGRES_PASSWORD), не из этой строки.
DB_DSN=host=postgres port=5432 user=nms-user password=your-postgres-password dbname=NMS sslmode=disable
# Для основного deploy/compose/docker-compose.yml (api/worker в host network):
# DB_SSLMODE управляет sslmode в DSN api/worker (default disable для локального single-host).
# Для production задайте минимум require (лучше verify-full при настроенных сертификатах).
DB_SSLMODE=disable
# Опционально: читать DSN из Docker secret-файла (приоритет выше DB_DSN)
# DB_DSN_FILE=/run/secrets/db_dsn
# Шифрование SNMP credential-полей в БД (community/auth_pass/priv_pass), рекомендуется для production.
# NMS_DB_ENCRYPTION_KEY=long-random-secret
# NMS_DB_ENCRYPTION_KEY_FILE=/run/secrets/nms_db_encryption_key
# Для ротации ключа (одноразово, во время процедуры re-encrypt):
# NMS_DB_ENCRYPTION_OLD_KEY=previous-long-random-secret
# NMS_DB_ENCRYPTION_OLD_KEY_FILE=/run/secrets/nms_db_encryption_old_key

# Telegram-бот для алертов (api, trap-receiver)
TELEGRAM_TOKEN=your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-chat-id
# TELEGRAM_TOKEN_FILE=/run/secrets/telegram_token
# TELEGRAM_CHAT_ID_FILE=/run/secrets/telegram_chat_id

# Inbound ITSM sync webhook token (POST /itsm/inbound):
# принимает Authorization: Bearer <token> или X-ITSM-Token.
# Если не задан — endpoint возвращает 503 (disabled).
# NMS_ITSM_INBOUND_TOKEN=change-me-long-random-token
# Alertmanager webhook token (POST /alerts/webhook):
# принимает Authorization: Bearer <token>.
# Если не задан — endpoint возвращает 401 на все запросы.
# NMS_ALERT_WEBHOOK_TOKEN=change-me-long-random-token
# (опционально) provider по умолчанию для mapping-rule lookup:
# NMS_ITSM_INBOUND_PROVIDER=generic

# SMTP для email-алертов (Alertmanager -> API webhook -> SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=change-me
SMTP_FROM=alerts@example.com
# Legacy override (не рекомендуется): разрешить plaintext SMTP без STARTTLS.
# NMS_SMTP_ALLOW_PLAINTEXT=false
# SMTP_USER_FILE=/run/secrets/smtp_user
# SMTP_PASS_FILE=/run/secrets/smtp_pass
# SMTP_FROM_FILE=/run/secrets/smtp_from

# Каталог загрузки MIB через веб (опционально; иначе из config.yaml / по умолчанию mibs/uploads)
# MIB_UPLOAD_DIR=/app/mibs/uploads

# Grafana (опционально)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password
# Base URL для role-aware ссылки на Incident SLA dashboard в UI (admin only).
# Пример: NMS_GRAFANA_BASE_URL=https://grafana.nms.example.com
# NMS_GRAFANA_BASE_URL=
# Base URL для health-бейджа Prometheus в dashboard UI (admin only, optional).
# Пример: NMS_PROMETHEUS_BASE_URL=https://prometheus.nms.example.com
# NMS_PROMETHEUS_BASE_URL=

# Traefik routing/ACME (актуально для deploy/compose/docker-compose*.yml)
# Email для Let's Encrypt account.
# TRAEFIK_ACME_EMAIL=ops@example.com
# Домены роутеров Traefik (bridge профиль и monitoring в host-профиле):
# NMS_APP_HOST=nms.test.com
# NMS_PROM_HOST=prom.nms.test.com
# NMS_GRAFANA_HOST=grafana.nms.test.com

# Веб-вход NMS1: по умолчанию fail-closed (если пары логина/пароля не заданы, сервис вернет 503).
# Форма /login + cookie-сессия; при желании можно использовать HTTP Basic.
# NMS_SESSION_SECRET настоятельно рекомендуется для production.
# NMS_ADMIN_USER=admin
# NMS_ADMIN_PASS=change-me
# NMS_VIEWER_USER=viewer
# NMS_VIEWER_PASS=change-me-too
# NMS_SESSION_SECRET=long-random-string
# NMS_ALLOW_NO_AUTH=false
# NMS_ADMIN_USER_FILE=/run/secrets/nms_admin_user
# NMS_ADMIN_PASS_FILE=/run/secrets/nms_admin_pass
# NMS_VIEWER_USER_FILE=/run/secrets/nms_viewer_user
# NMS_VIEWER_PASS_FILE=/run/secrets/nms_viewer_pass
# NMS_SESSION_SECRET_FILE=/run/secrets/nms_session_secret

# Incident auto-assignment policy (optional on-call baseline):
# - critical incidents -> NMS_INCIDENT_ASSIGNEE_CRITICAL
# - source-specific fallback -> *_TRAP / *_POLLING / *_MANUAL
# - global fallback -> NMS_INCIDENT_ASSIGNEE_DEFAULT
# NMS_INCIDENT_ASSIGNEE_CRITICAL=oncall-l2
# NMS_INCIDENT_ASSIGNEE_TRAP=netops
# NMS_INCIDENT_ASSIGNEE_POLLING=noc
# NMS_INCIDENT_ASSIGNEE_MANUAL=service-desk
# NMS_INCIDENT_ASSIGNEE_DEFAULT=noc

# Auto-escalation for unacknowledged incidents (worker):
# - only incidents in status=new are escalated
# - requires BOTH timeout and target assignee
# NMS_INCIDENT_ESCALATION_ACK_TIMEOUT=15m
# NMS_INCIDENT_ASSIGNEE_ESCALATION=oncall-l3
# NMS_INCIDENT_ESCALATION_CHECK_INTERVAL=1m
#
# Escalation v2 (optional, policy-based):
# Stage2 (after longer timeout, can reassign from stage1):
# NMS_INCIDENT_ESCALATION_STAGE2_ACK_TIMEOUT=30m
# NMS_INCIDENT_ESCALATION_STAGE2_ASSIGNEE=incident-manager
# Severity override for stage1:
# NMS_INCIDENT_ESCALATION_CRITICAL_ACK_TIMEOUT=5m
# NMS_INCIDENT_ESCALATION_CRITICAL_ASSIGNEE=sev1-oncall
# Source overrides for stage1:
# NMS_INCIDENT_ESCALATION_TRAP_ACK_TIMEOUT=8m
# NMS_INCIDENT_ESCALATION_TRAP_ASSIGNEE=netops-oncall
# NMS_INCIDENT_ESCALATION_POLLING_ACK_TIMEOUT=12m
# NMS_INCIDENT_ESCALATION_POLLING_ASSIGNEE=noc-l2
# NMS_INCIDENT_ESCALATION_MANUAL_ACK_TIMEOUT=20m
# NMS_INCIDENT_ESCALATION_MANUAL_ASSIGNEE=service-desk-l2

# Terminal WS security (admin page /devices/{id}/terminal):
# - по умолчанию strict Origin-check и строгая проверка SSH host key.
# - для SSH укажите known_hosts-файл; insecure режимы только временно/осознанно.
# NMS_TERMINAL_SSH_KNOWN_HOSTS=/app/secrets/known_hosts
# NMS_TERMINAL_ALLOW_INSECURE_HOSTKEY=false
# NMS_TERMINAL_ALLOW_INSECURE_ORIGIN=false

# HTTP server hardening (опционально):
# NMS_HTTP_READ_HEADER_TIMEOUT=5s
# NMS_HTTP_READ_TIMEOUT=15s
# NMS_HTTP_WRITE_TIMEOUT=30s
# NMS_HTTP_IDLE_TIMEOUT=60s
# NMS_HTTP_MAX_HEADER_BYTES=1048576
# NMS_WORKER_HTTP_READ_HEADER_TIMEOUT=5s
# NMS_WORKER_HTTP_READ_TIMEOUT=10s
# NMS_WORKER_HTTP_WRITE_TIMEOUT=20s
# NMS_WORKER_HTTP_IDLE_TIMEOUT=60s
# NMS_WORKER_HTTP_MAX_HEADER_BYTES=1048576
# Worker poll scaling (опционально):
# NMS_WORKER_POLL_CONCURRENCY=4
# NMS_WORKER_POLL_RATE_LIMIT_PER_SEC=0

# Optional internal gRPC pilot:
# - API/server can expose trap ingest gRPC endpoint.
# - trap-receiver can forward traps to API over gRPC instead of direct DB writes.
# Security guardrail: wildcard binds (:9091 / 0.0.0.0) are blocked unless explicitly allowed.
# NMS_GRPC_ALLOW_PUBLIC_BIND=false
# Host-network profile (deploy/compose/docker-compose.yml):
# NMS_GRPC_ADDR=127.0.0.1:9091
# NMS_TRAP_GRPC_TARGET=127.0.0.1:9091
# Bridge profile (deploy/compose/docker-compose.bridge.yml):
# NMS_GRPC_ADDR=:9091
# NMS_TRAP_GRPC_TARGET=nms1-api-1:9091
# Optional gRPC auth (recommended):
# - Server validates bearer token from metadata authorization header.
# NMS_GRPC_AUTH_TOKEN=change-me-long-random-token
# NMS_TRAP_GRPC_AUTH_TOKEN=change-me-long-random-token
# Optional gRPC TLS (recommended for production):
# - Server TLS:
# NMS_GRPC_TLS_CERT_FILE=/run/secrets/nms_grpc_tls_cert.pem
# NMS_GRPC_TLS_KEY_FILE=/run/secrets/nms_grpc_tls_key.pem
# - Optional mTLS on server:
# NMS_GRPC_TLS_CLIENT_CA_FILE=/run/secrets/nms_grpc_tls_client_ca.pem
# - trap-receiver TLS client:
# NMS_TRAP_GRPC_TLS_CA_FILE=/run/secrets/nms_grpc_tls_ca.pem
# NMS_TRAP_GRPC_TLS_SERVER_NAME=nms-api.internal
# - Optional trap-receiver client cert for mTLS:
# NMS_TRAP_GRPC_TLS_CERT_FILE=/run/secrets/nms_trap_grpc_tls_cert.pem
# NMS_TRAP_GRPC_TLS_KEY_FILE=/run/secrets/nms_trap_grpc_tls_key.pem

# HTTPS-only policy (production): redirect plain HTTP to HTTPS (except /health and /metrics).
# NMS_ENFORCE_HTTPS=true

# Session revocation safety (optional override):
# If shared revocation store is unavailable, production defaults to fail-closed.
# For controlled dev-only fail-open behavior:
# NMS_SESSION_REVOCATION_FAIL_CLOSED=false

# Production guardrails:
# Если NMS_ENV=production, все сервисы требуют:
# - NMS_DB_ENCRYPTION_KEY
# - DB_DSN без sslmode=disable
# Для API дополнительно требуются:
# - NMS_SESSION_SECRET
# - NMS_TERMINAL_SSH_KNOWN_HOSTS
# - NMS_ENFORCE_HTTPS=true
# Для API запрещены insecure-flags:
# - NMS_ALLOW_NO_AUTH
# - NMS_TERMINAL_ALLOW_INSECURE_ORIGIN
# - NMS_TERMINAL_ALLOW_INSECURE_HOSTKEY
