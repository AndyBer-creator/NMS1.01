# Копируйте в .env и подставьте свои значения. Файл .env не коммитить!

# PostgreSQL (контейнер postgres)
POSTGRES_DB=NMS
POSTGRES_USER=nms-user
POSTGRES_PASSWORD=your-postgres-password

# Строка подключения к БД (для api, worker, trap-receiver, миграций)
# Для Docker: host=postgres, для локального запуска: host=localhost
DB_DSN=host=postgres port=5432 user=nms-user password=your-postgres-password dbname=NMS sslmode=disable

# Telegram-бот для алертов (api, trap-receiver)
TELEGRAM_TOKEN=your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-chat-id

# Grafana (опционально)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password
